{
  "name": "devflow-backend",
  "version": "1.0.0",
  "description": "Backend for DevFlow with API + Worker architecture",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "tsc",
    "clean": "rimraf dist",
    "build:clean": "npm run clean && npm run build",
   "start": "npx prisma migrate deploy && node dist/server.js",
    "start:worker": "npx prisma migrate deploy && node dist/worker.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:worker\"",
    "start:all": "concurrently \"npm run start\" \"npm run start:worker\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/dotenv": "^6.1.1",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "ollama": "^0.6.3",
    "rimraf": "^6.1.3",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/socket.io": "^3.0.1",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
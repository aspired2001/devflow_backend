generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}

model User {
 id        String   @id @default(uuid())
 email     String   @unique
 password  String
 createdAt DateTime @default(now())

 projects  Project[]
 comments  Comment[] 
  adrs      Adr[]   
}

model Project {
 id        String   @id @default(uuid())
 name      String
 ownerId   String
 createdAt DateTime @default(now())

 owner     User     @relation(fields: [ownerId], references: [id])
 diagrams  Diagram[]
}

model Diagram {
 id        String   @id @default(uuid())
 projectId String   @unique
 createdAt DateTime @default(now())

 project   Project  @relation(fields: [projectId], references: [id])
 versions  Version[]
}

model Version {
 id        String   @id @default(uuid())
 diagramId String
 version   Int
 data      Json
 createdAt DateTime @default(now())

 diagram   Diagram  @relation(fields: [diagramId], references: [id])
}
model Comment {
  id         String   @id @default(uuid())
  content    String

  projectId  String
  diagramId  String?
  nodeId     String?

  parentId   String?
  parent     Comment? @relation("Thread", fields: [parentId], references: [id])
  replies    Comment[] @relation("Thread")

  userId     String
  user       User     @relation(fields: [userId], references: [id])

  createdAt  DateTime @default(now())
}
model Adr {
  id           String   @id @default(uuid())
  projectId    String
  title        String
  decision     String
  reason       String
  consequences String?
  status       String

  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])

  createdAt    DateTime @default(now())
}

model AiReview {
  id        String   @id @default(uuid())
  projectId String
  hash      String
  result    Json?
  status    String   // pending | completed | failed
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([hash])
}